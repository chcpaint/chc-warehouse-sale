# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (generate a strong random string)
JWT_SECRET=your-jwt-secret-min-32-chars

# Server Configuration
PORT=3000
NODE_ENV=production
# Public base URL (used for CORS in production)
APP_URL=https://chc-sale-console-production.up.railway.app

# Online Payments (Stripe) — OPTIONAL / pre-wired but disabled until set.
# Leave blank to keep the PO-only checkout. When set, also flip
# companies.settings.payments.enabled = true for the tenant(s) that should accept cards.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=orders@chcpaint.com

# CHC Branding
CHC_LOGO_URL=/assets/chc-logo.png

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload Limits (bytes)
MAX_CATALOG_SIZE=10485760
MAX_LOGO_SIZE=2097152
